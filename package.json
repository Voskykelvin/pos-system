{
  "name": "pos-system",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node server.js\" \"vite --host 0.0.0.0\"",
    "dev:api": "node server.js",
    "dev:web": "vite --host 0.0.0.0",
    "admin:create": "node scripts/create-admin.js",
    "build": "vite build",
    "db:sync": "node scripts/sync-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:dry": "node scripts/migrate.js --dry-run",
    "start": "node server.js",
    "smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pg-mem": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sequelize": "^6.37.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.3.0"
  }
}
