{
  "name": "jijenge-pos",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node server.js\" \"vite --host 0.0.0.0\"",
    "dev:api": "node server.js",
    "dev:web": "vite --host 0.0.0.0",
    "start:prod": "NODE_ENV=production node server.js",
    "admin:create": "node scripts/create-admin.js",
    "build": "vite build",
    "test:bundle": "node scripts/bundle-budget.js",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write .",
    "test": "npm run test:unit && npm run smoke",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && npm run test:e2e:run",
    "test:e2e:run": "playwright test",
    "test:postgres": "node scripts/postgres-invariants-test.js",
    "test:load": "node scripts/load-smoke.js",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:dry": "node scripts/migrate.js --dry-run",
    "db:backup": "node scripts/backup-postgres.js",
    "db:verify-backup": "node scripts/verify-backup.js",
    "ops:snapshot": "node scripts/incident-snapshot.js",
    "db:reset-demo-catalog": "node scripts/reset-demo-catalog.js",
    "start": "node server.js",
    "smoke": "node scripts/auth-token-test.js && node scripts/held-sales-smoke.mjs && node scripts/receipt-snapshot-test.js && node scripts/fiscal-guard-test.js && node scripts/financial-invariants-test.js && node scripts/smoke-test.js"
  },
  "dependencies": {
    "@zxing/browser": "0.1.5",
    "axios": "^1.7.0",
    "compression": "^1.8.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "idb": "^8.0.3",
    "jsbarcode": "^3.11.6",
    "node-cron": "^4.5.0",
    "pg": "^8.12.0",
    "pg-mem": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.1",
    "sequelize": "^6.37.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "fake-indexeddb": "^6.2.4",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
