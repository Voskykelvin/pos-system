{
  "name": "jijenge-pos",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node server.js\" \"vite --host 0.0.0.0\"",
    "dev:api": "node server.js",
    "dev:web": "vite --host 0.0.0.0",
    "start:prod": "NODE_ENV=production node server.js",
    "admin:create": "node scripts/create-admin.js",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write .",
    "test": "npm run smoke",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:dry": "node scripts/migrate.js --dry-run",
    "db:reset-demo-catalog": "node scripts/reset-demo-catalog.js",
    "start": "node server.js",
    "smoke": "node scripts/held-sales-smoke.mjs && node scripts/receipt-snapshot-test.js && node scripts/fiscal-guard-test.js && node scripts/smoke-test.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "compression": "^1.8.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "idb": "^8.0.3",
    "jsbarcode": "^3.11.6",
    "node-cron": "^4.5.0",
    "pg": "^8.12.0",
    "pg-mem": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.1",
    "sequelize": "^6.37.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.0.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
