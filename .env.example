# Leave DATABASE_URL blank for the built-in in-memory demo database.
# Set it for a real PostgreSQL database in production.
DATABASE_URL=
DB_SSL=false
DB_SYNC=false
SEED_DEMO_DATA=false
ENABLE_ETIMS_SCHEDULER=false

PORT=4000
BUSINESS_NAME=My Mini Supermarket
BUSINESS_KRA_PIN=
BUSINESS_TIME_ZONE=Africa/Nairobi
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_HOURS=12

ADMIN_NAME=Store Admin
ADMIN_EMAIL=
ADMIN_PHONE=
ADMIN_PASSWORD=

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

ETIMS_ENV=sandbox
ETIMS_BASE_URL=
ETIMS_API_KEY=
ETIMS_DEVICE_SERIAL=
